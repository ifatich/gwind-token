{
    "compilerOptions": {
        "outDir": "./dist",
        "moduleResolution": "node16",
        "module": "Node16",
        "target": "ES6",
        "declaration": true,
        "declarationMap": true,
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": [
        "src/**/*",
        "scripts/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}